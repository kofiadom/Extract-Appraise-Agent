# Application
NODE_ENV=development
PORT=3000

# Redis (BullMQ queue backend)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL (NestJS — users + pipeline_jobs)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-with-a-strong-random-password
DB_NAME=agno_rag

# JWT
# IMPORTANT: Change this to a long random string before deploying.
# The service will refuse to start with this default value in production.
JWT_SECRET=replace-with-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# FastAPI service URL (called by NestJS workers)
FASTAPI_URL=http://localhost:8000

# Job Queue
MAX_RETRY_ATTEMPTS=3
JOB_TIMEOUT=600000
PIPELINE_MAX_WAIT_MS=900000
INDEX_MAX_WAIT_MS=300000
# How many pipeline jobs the BullMQ worker runs in parallel.
# Keep this in sync with MAX_CONCURRENT_DOCS in the FastAPI .env.
WORKER_CONCURRENCY=3

# FastAPI proxy timeouts
FASTAPI_REQUEST_TIMEOUT_MS=30000
FASTAPI_UPLOAD_TIMEOUT_MS=600000
FASTAPI_INDEX_START_TIMEOUT_MS=60000
FASTAPI_CHAT_TIMEOUT_MS=120000

# Upload cap (enforced in PapersController)
MAX_DOCS_PER_RUN=5

# CORS — comma-separated list of allowed origins, or * to allow all (dev only)
# Example: CORS_ORIGIN=https://app.example.com,https://www.example.com
CORS_ORIGIN=*

# Throttling — 100 requests per 60 seconds per IP by default
ENABLE_THROTTLING=true
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging — pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# API Docs (set to false in production)
ENABLE_SWAGGER=true
