# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Model selection (see README for available models)
BEDROCK_MODEL_ID=zai.glm-5

# LlamaParse — get key at https://cloud.llamaindex.ai
LLAMAPARSE_API_KEY=

# Agent mode (filesearch is the only supported mode)
AGENT_METHOD=filesearch

# Production CORS origins (comma-separated, leave blank for localhost only)
# Use * to allow all origins (PoC/Coolify deployments), or list exact domains:
# CORS_ORIGINS=https://your-frontend.coolify.io,https://your-backend.coolify.io
CORS_ORIGINS=
